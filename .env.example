# Copy this file to .env for local development. Never commit .env.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-for-local-development
POSTGRES_DB=cspm
DATABASE_URL=postgresql://postgres:change-me-for-local-development@postgres:5432/cspm


# Phase 2 backend database (SQLModel + Alembic).
# The line above is the Docker Compose Postgres URL used by the API container.
# For local Phase 2 development you can instead use a zero-setup SQLite file:
#   DATABASE_URL=sqlite:///./cloud_security.db
# For production, use a managed Postgres (e.g. Neon) connection string:
#   DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Replace with a long random value before implementing authentication.
JWT_SECRET=replace-with-a-long-random-secret

# Deployment environment: "development" (default) or "production". In production
# the placeholder dev user is NOT auto-created — requests without a real user are
# rejected with 401 until authentication lands in Phase 8.
CSPM_ENV=development

# Cross-Origin Resource Sharing. Empty by default (no browser origin allowed).
# Set to the frontend origin(s), comma-separated, so the Phase 3 React dashboard
# can call the API, e.g.:
#   CORS_ALLOW_ORIGINS=http://localhost:5173
# Phase 8 tightens this to the deployed frontend origin only.
CORS_ALLOW_ORIGINS=

# Optional: override where the rule engine loads YAML rules from (defaults to
# the repository's /rules directory).
# RULES_DIR=/app/rules

LOCALSTACK_ENDPOINT=http://localstack:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
