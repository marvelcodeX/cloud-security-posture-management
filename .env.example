# Copy this file to .env for local development. Never commit .env.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-for-local-development
POSTGRES_DB=cspm
DATABASE_URL=postgresql://postgres:change-me-for-local-development@postgres:5432/cspm

# Replace with a long random value before implementing authentication.
JWT_SECRET=replace-with-a-long-random-secret

LOCALSTACK_ENDPOINT=http://localstack:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
